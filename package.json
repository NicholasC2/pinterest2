{
  "name": "pinterest2",
  "version": "1.0.0",
  "description": "pinterest but 2",
  "license": "ISC",
  "author": "NicholasC2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"tsx watch src/index.ts\" \"esbuild src/client/index.ts --bundle --platform=browser --outfile=static/assets/js/client.js --watch --log-level=info\"",
    "build:server": "tsc",
    "build:client": "esbuild src/client/index.ts --bundle --minify --platform=browser --outfile=static/assets/js/client.js",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/masonry-layout": "^4.2.8",
    "@types/node": "^24.13.2",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "express": "^5.2.1",
    "lowdb": "^7.0.1",
    "masonry-layout": "^4.2.2"
  }
}
